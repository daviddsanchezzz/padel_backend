PORT=3001
MONGODB_URI=mongodb://localhost:27017/padel
NODE_ENV=development

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_super_secret_key_min_32_chars
BETTER_AUTH_URL=http://localhost:3001

# Frontend origin (used for CORS and trustedOrigins)
FRONTEND_URL=http://localhost:5173

# Google OAuth
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
